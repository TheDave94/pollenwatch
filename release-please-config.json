{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "packages": {
    ".": {
      "extra-files": [
        {
          "type": "json",
          "path": "custom_components/pollenwatch/manifest.json",
          "jsonpath": "$.version"
        },
        {
          "type": "toml",
          "path": "pyproject.toml",
          "jsonpath": "$.project.version"
        }
      ]
    }
  }
}
