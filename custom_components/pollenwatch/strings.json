{
  "title": "PollenWatch",
  "config": {
    "step": {
      "user": {
        "title": "Add a PollenWatch location",
        "description": "Pollen data comes from the Copernicus Atmosphere Monitoring Service (CAMS) via Open-Meteo (always-on) and up to five optional regional sources you can enable in Options after setup. The location is fixed once set — to move it later, remove and re-add the integration.",
        "data": {
          "location": "Location"
        },
        "data_description": {
          "location": "Pick the point to monitor. Open-Meteo snaps it to the nearest ~10 km grid cell."
        }
      },
      "species": {
        "title": "Species to track",
        "description": "Species commonly tracked in your country ({country}) are pre-selected ({default_count} of {available_count} locally-available). Toggle the cross-validated core for a one-click default of the {core_count} most-validated species — alder, birch, grass, hazel, mugwort, ragweed, olive, ash. Only species at least one source can cover at your location appear; enable additional sources in Options after setup to unlock more.",
        "data": {
          "selected_species": "Species to track",
          "use_cross_validated_core": "Use cross-validated core (overrides selection above)"
        },
        "data_description": {
          "selected_species": "Each selected species creates sensors per active source. Unselected species don't create any entities, keeping the install lean.",
          "use_cross_validated_core": "The 8 species with both high allergenic potency AND coverage from at least 3 sources globally — a sane default for users who don't want to think about it."
        }
      }
    },
    "error": {
      "out_of_coverage": "This location is outside CAMS European coverage. Choose a location within Europe.",
      "cannot_connect": "Could not reach Open-Meteo. Check your connection and try again.",
      "no_species": "Select at least one species (or toggle the cross-validated core)."
    },
    "abort": {
      "already_configured": "This location is already configured."
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "PollenWatch options",
        "description": "The location is fixed; remove and re-add the integration to change it.",
        "data": {
          "selected_species": "Species to track",
          "default_layout": "Default card layout",
          "update_interval": "Update interval (minutes)",
          "enable_polleninformation": "Enable polleninformation.at (second source)",
          "country": "Country (polleninformation)",
          "api_key": "polleninformation API key",
          "sensitivity_alder": "Alder sensitivity (×)",
          "sensitivity_birch": "Birch sensitivity (×)",
          "sensitivity_grass": "Grass sensitivity (×)",
          "sensitivity_mugwort": "Mugwort sensitivity (×)",
          "sensitivity_olive": "Olive sensitivity (×)",
          "sensitivity_ragweed": "Ragweed sensitivity (×)",
          "enable_dwd": "Enable DWD Pollenflug (Germany, third source)",
          "region": "DWD region",
          "enable_meteoswiss": "Enable MeteoSwiss (Switzerland)",
          "enable_epin": "Enable ePIN (Bavaria)",
          "enable_google": "Enable Google Pollen API (global)",
          "google_api_key": "Google Pollen API key"
        },
        "data_description": {
          "default_layout": "Default layout for PollenWatch's bundled Lovelace card. 'gauge' is the per-species severity gauge (one card per species). 'bars', 'compact', and 'tiles' are multi-species overview layouts (PollenWatch v2.4+). Individual cards can override this default by setting `layout:` in their card YAML.",
          "update_interval": "How often to poll Open-Meteo. Minimum 60 minutes to be a good citizen on a free public API.",
          "enable_polleninformation": "Adds a second source. Requires a free API key from polleninformation.at.",
          "country": "The country whose pollen network covers your location.",
          "api_key": "Stored encrypted in Home Assistant; never written to disk in plain text.",
          "enable_dwd": "Adds the Deutscher Wetterdienst forecast. Germany only; no API key needed.",
          "region": "Your DWD forecast region within Germany.",
          "enable_meteoswiss": "Adds the MeteoSwiss automatic network. Switzerland only; no API key. The nearest measuring station is picked automatically — currently: {ms_station}.",
          "enable_epin": "Adds the ePIN automatic network. Bavaria only; no API key. The nearest measuring station is picked automatically — currently: {epin_station}.",
          "enable_google": "Adds the Google Pollen API: global coverage, 5-day forecast, all six allergens (incl. olive — the only source with it). Requires a Google Cloud project with the Pollen API enabled AND a billing account attached. A free tier exists (~5,000 requests/month) but Google requires a payment method on file, so this is more involved than the other sources' free keys.",
          "google_api_key": "Stored encrypted in Home Assistant; never written to disk in plain text. Consensus-only: Google's licence forbids storing its forecasts, so it is not used for the recent-percentile baseline."
        }
      }
    },
